# 大文件 / 可由脚本重新生成的产物，不入库
data/npy/
data/frames/
data/dataset_calib*.txt
data/eval_turn.txt
model/*.onnx
model/*.rknn

# 临时文件
__pycache__/
*.pyc
*.model
*.data
*.quantization.cfg

# Phase 2（板上推理程序）
board/act-rknn/target/
board/rknn_runtime/aarch64/*.so

# 板上部署包（由 scripts/package_board.sh 重建）
board_pkg/

# StarryOS 载荷（106MB，由 assemble_payload.sh 重建）
starryos_npu/app/payload/

# StarryOS 交付大产物（内核/rootfs/dtb，可重建，留 README）
starryos_npu/deliverable/*.img
starryos_npu/deliverable/*.bin
starryos_npu/deliverable/*.dtb
starryos_npu/research/rknpu_ioctl.h
starryos_npu/*.zip
